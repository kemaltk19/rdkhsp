# === Radikal Hesap Lite — Ortam Değişkenleri Örneği ===
# Kopyalayın: cp .env.example .env  (ve değerleri doldurun)

# development | production
APP_ENV=development
PORT=9001

# İKİ AYRI DSN ZORUNLU (RLS mimarisi):
#  - radikal_app    : normal uygulama rolü (RLS uygulanır)
#  - radikal_system : BYPASSRLS sistem rolü (kayıt/seed/superadmin)
# Lokal: host=localhost | Docker: host=db
# Canlı (production): sslmode=disable yerine sslmode=require kullanın.
DATABASE_URL=postgres://radikal_app:app_pass@localhost:5432/radikal_hesap?sslmode=disable
SYSTEM_DATABASE_URL=postgres://radikal_system:sys_pass@localhost:5432/radikal_hesap?sslmode=disable

# JWT imza anahtarı. PRODUCTION'da zorunlu, >=24 karakter, rastgele.
# (production'da boş/varsayılan/zayıf değer uygulamayı başlatmaz)
JWT_SECRET=degistir-uzun-rastgele-key-for-local-testing
ACCESS_TTL=15m
REFRESH_TTL=168h

# HTTPS arkasında (production) true olmalı.
COOKIE_SECURE=false

# Billing webhook imza doğrulama anahtarı (HMAC-SHA256).
# /api/billing/webhook public bir endpoint olduğundan ZORUNLUDUR; boş bırakılırsa
# tüm webhook istekleri reddedilir. Sağlayıcı "Stripe-Signature" header'ında
# hex(HMAC_SHA256(WEBHOOK_SECRET, raw_body)) göndermelidir.
WEBHOOK_SECRET=degistir-uzun-rastgele-webhook-secret

# CORS izinli origin(ler). Virgülle birden fazla verilebilir.
FRONTEND_ORIGIN=http://localhost:9000

# Müşteriye gönderilen mail linklerinin (fatura/teklif public sayfaları) tabanı.
# Lokal: http://localhost:9000 | Canlı: https://app.radikalhesap.com gibi gerçek domain.
PUBLIC_APP_URL=http://localhost:9000

# İlk superadmin (sadece ilk kurulumda seed edilir).
SUPERADMIN_EMAIL=admin@radikalhesap.com
SUPERADMIN_PASSWORD=change_me_admin_2026

# SMTP (e-posta) — opsiyonel
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@radikalhesap.com
